# Port (optional, default 3000)
PORT=3000

# Business email used for calendar and "from" address
BUSINESS_EMAIL=webcraft404@gmail.com

# Google Calendar: use the primary calendar of the account that owns the Service Account,
# or the calendar shared with it (see SETUP.md).
CALENDAR_ID=primary

# --- Google Calendar API (Service Account) ---
# Option A: Path to the JSON key file downloaded from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# Option B: Base64-encoded JSON key (e.g. echo -n '{"type":"service_account",...}' | base64)
# GOOGLE_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# --- Email (Nodemailer) ---
# For Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=webcraft404@gmail.com
SMTP_PASS=your-app-password-here
